# Postgres connection string (Supabase: Project Settings → Database → Connection
# string, "Session pooler" URI). Used by the Express server and drizzle-kit.
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# Secret for signing Express session cookies. Any long random string.
SESSION_SECRET=

# Anthropic API key — powers the AI blurb/screenshot parsers and artist analysis.
ANTHROPIC_API_KEY=

# Optional: Spotify app credentials for artist lookup enrichment.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Optional: Serper.dev key used by the automated concert discovery service.
SERPER_API_KEY=

# Optional: PostHog project API key for page-view analytics.
VITE_POSTHOG_KEY=
